@{
    ViewData["Title"] = "Code Murders";
}

<section class="hero text-center">
    <h1 class="hero-title">Code Murders</h1>
    <p class="hero-subtitle">Investigate the evidence. Find the bug. Identify the guilty commit.</p>
    <p class="hero-description">
        Step into the role of an investigator. Examine log entries, trace the commit history,
        and analyze the source code to uncover which change broke the system.
    </p>
    <div class="hero-actions">
        <a href="#" class="btn btn-danger btn-lg btn-hero-primary">Start Investigation</a>
        <a href="#" class="btn btn-outline-light btn-lg btn-hero-secondary">View Project Plan</a>
    </div>
</section>

<section class="features-section">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Inspect Logs</h3>
                <p>Read through system log entries to find when and where things went wrong.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Review Commits</h3>
                <p>Trace the commit history to see what changed and who changed it.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3>Analyze Code</h3>
                <p>Study the affected code to understand how the bug was introduced.</p>
            </div>
        </div>
    </div>
</section>

<section class="case-section">
    <div class="case-card">
        <div class="case-info">
            <span class="case-label">First Case</span>
            <h2 class="case-title">The Midnight Order Service Crash</h2>
        </div>
        <span class="case-status">Coming Soon</span>
    </div>
</section>
